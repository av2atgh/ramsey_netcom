# Makefile — reproduce the figures and statistical tests for the manuscript
# "The number of communities in real networks grows as a power law of size".
#
#   make            # default: build the four figures and run the two tests
#   make figures    # just the four figure PDFs
#   make tests      # density + geography significance tests (printed to stdout)
#   make data       # RE-generate the CSVs from scratch — SLOW: needs graph-tool
#                   # and downloads networks from Netzschleuder (hours)
#   make clean      # remove the generated figure PDFs
#
# The figures and tests build from the committed CSVs and only need
# numpy/pandas/matplotlib/scipy — no network access.  Override the interpreter
# with e.g.  make PY=python3

PY ?= python

FIGS := fig1.pdf fig2.pdf fig_examples.pdf fig_models.pdf

.PHONY: all figures tests data clean
all: figures tests

figures: $(FIGS)

# --- figures ------------------------------------------------------------------
# Each figure depends on its script and (where applicable) its data CSV, so it
# is rebuilt whenever either changes.  A *missing* CSV is generated by the rules
# below; an existing CSV is never regenerated on its own (that is slow — use the
# explicit `data` target).

fig1.pdf: plot_from_csv.py communities_vs_n.csv
	$(PY) plot_from_csv.py

fig2.pdf: make_fig2.py
	$(PY) make_fig2.py

fig_examples.pdf: plot_examples.py examples_communities.csv
	$(PY) plot_examples.py

fig_models.pdf: models_plot.py models_communities.csv
	$(PY) models_plot.py

# --- statistical tests --------------------------------------------------------
tests: communities_vs_n.csv
	@echo "===== density test (above vs below the fit line) ====="
	$(PY) density_test.py
	@echo
	@echo "===== geography test (geographic vs non-geographic) ====="
	$(PY) geography_test.py

# --- data (re)generation — slow, requires graph-tool --------------------------
# These generators APPEND to their CSV and skip already-computed rows.  The
# rules below build a CSV only if it is missing; `make data` forces a clean
# rebuild of all three.
communities_vs_n.csv:
	$(PY) run_sbm.py

examples_communities.csv:
	$(PY) examples_communities.py

models_communities.csv:
	$(PY) models_communities.py

data:
	rm -f communities_vs_n.csv examples_communities.csv models_communities.csv
	$(PY) run_sbm.py
	$(PY) examples_communities.py
	$(PY) models_communities.py

clean:
	rm -f $(FIGS)
